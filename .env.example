# Copy this file to .env and adjust the values before running docker compose.

# --- PostgreSQL ---
POSTGRES_DB=defectdojo
POSTGRES_USER=defectdojo
POSTGRES_PASSWORD=changeme

# --- DefectDojo application ---
# Django secret key - must be a long, random, unique string in production.
DD_SECRET_KEY=changeme-replace-with-a-strong-random-secret

# Comma-separated list of allowed hostnames / IPs (no wildcards in production).
DD_ALLOWED_HOSTS=localhost,127.0.0.1

# Admin account created on first startup.
DD_ADMIN_USER=admin
DD_ADMIN_PASSWORD=changeme
DD_ADMIN_MAIL=admin@example.com

DD_TIME_ZONE=UTC

# --- Exposed port for the Nginx reverse proxy ---
DD_PORT=8080

# --- scope-guardian CLI ---
# Set these when running the CLI so it can reach the DefectDojo API.
DD_URL=http://localhost:8080
DD_ACCESS_TOKEN=<paste-your-defectdojo-api-token-here>
